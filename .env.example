PORT=3000
NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgres://postgres:postgres@localhost:5432/mfos_outbound
DB_POOL_MAX=10
DB_SSL=false

AUTH_MODE=dev
SSO_ISSUER=https://example-idp.local/
SSO_AUDIENCE=mfos-outbound-enforcement-service
SSO_JWKS_URI=https://example-idp.local/.well-known/jwks.json

DEV_USER_ID=11111111-1111-1111-1111-111111111111
DEV_ORG_ID=00000000-0000-0000-0000-000000000001

OUTBOX_POLL_MS=2000
OUTBOX_BATCH_SIZE=25
TRANSPORT_MODE=log
